<ui:FluentWindow x:Class="YoutubeConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:YoutubeConverter.ViewModels"
        Title="YouTube Converter"
        Icon="app.ico"
        Width="560"
        MinWidth="560"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <ui:FluentWindow.DataContext>
        <vm:MainViewModel />
    </ui:FluentWindow.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="YouTube Converter">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="24,12,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBlock Text="Youtube video converter" FontTypography="BodyStrong" />
                        <ui:TextBlock Text="{Binding AppVersion}"
                                      FontTypography="Caption"
                                      Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <ui:Button x:Name="HistoryButton"
                               Icon="{ui:SymbolIcon Symbol=History24}"
                               ToolTip="Historik"
                               Margin="0,0,8,0"
                               Click="HistoryButton_Click" />
                    <ui:Button x:Name="UpdatesButton"
                               Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                               ToolTip="Uppdateringar"
                               Margin="0,0,8,0"
                               Click="UpdatesButton_Click">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateAvailable}" Value="True">
                                        <Setter Property="Appearance" Value="Caution" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button x:Name="ContactButton"
                               Icon="{ui:SymbolIcon Symbol=Mail24}"
                               ToolTip="Kontakt"
                               Margin="0,0,8,0"
                               Click="ContactButton_Click" />
                    <ui:Button x:Name="InfoButton"
                               Icon="{ui:SymbolIcon Symbol=Info24}"
                               ToolTip="Information"
                               Click="InfoButton_Click" />
                </StackPanel>

                <Popup x:Name="HistoryPopup"
                       PlacementTarget="{Binding ElementName=HistoryButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="-220">
                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,6,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" />
                        </Border.Effect>
                        <StackPanel Width="440">
                            <Grid Margin="0,0,0,6">
                                <ui:TextBlock Text="Historik" FontTypography="BodyStrong" HorizontalAlignment="Left" />
                                <ui:Button Content="Rensa allt"
                                           HorizontalAlignment="Right"
                                           Padding="8,2"
                                           Command="{Binding ClearHistoryCommand}"
                                           Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>

                            <ui:TextBlock Text="Inga nedladdningar än."
                                          FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Margin="0,8"
                                          HorizontalAlignment="Center">
                                <ui:TextBlock.Style>
                                    <Style TargetType="ui:TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasHistory}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:TextBlock.Style>
                            </ui:TextBlock>

                            <ListBox ItemsSource="{Binding History}"
                                     MaxHeight="420"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="32">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{DynamicResource AccentFillColorTertiaryBrush}"
                                                    CornerRadius="3"
                                                    Height="18"
                                                    Width="36"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <ui:TextBlock Text="{Binding Format}"
                                                              FontTypography="Caption"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                            </Border>
                                            <ui:TextBlock Grid.Column="1"
                                                          Text="{Binding Title}"
                                                          FontTypography="Caption"
                                                          VerticalAlignment="Center"
                                                          TextTrimming="CharacterEllipsis"
                                                          Margin="0,0,8,0" />
                                            <ui:TextBlock Grid.Column="2"
                                                          Text="{Binding Timestamp, StringFormat='{}{0:MM-dd HH:mm}'}"
                                                          FontTypography="Caption"
                                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0" />
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:Button Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                                                           ToolTip="Öppna mapp"
                                                           Padding="4,2"
                                                           Margin="0,0,2,0"
                                                           Command="{Binding DataContext.OpenHistoryItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                           CommandParameter="{Binding}" />
                                                <ui:Button Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                                           ToolTip="Ta bort"
                                                           Padding="4,2"
                                                           Command="{Binding DataContext.RemoveHistoryItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                           CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup x:Name="UpdatesPopup"
                       PlacementTarget="{Binding ElementName=UpdatesButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="-160">
                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,6,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" />
                        </Border.Effect>
                        <StackPanel Width="280">
                            <ui:TextBlock Text="Uppdateringar" FontTypography="BodyStrong" Margin="0,0,0,10" />

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="Aktuell version:" FontTypography="Caption"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ui:TextBlock Grid.Column="1" Text="{Binding AppVersion}" FontTypography="Caption" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="Senaste version:" FontTypography="Caption"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ui:TextBlock Grid.Column="1" Text="{Binding LatestVersionText}" FontTypography="Caption" />
                            </Grid>

                            <ui:Button Content="Ladda ner ny version"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,0,6"
                                       Command="{Binding OpenUpdateCommand}"
                                       Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <ui:Button Content="Kontrollera uppdateringar"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,0,6"
                                       Command="{Binding CheckUpdatesCommand}" />

                            <ui:Button Content="Öppna GitHub-repo"
                                       HorizontalAlignment="Stretch"
                                       Command="{Binding OpenRepoCommand}" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup x:Name="ContactPopup"
                       PlacementTarget="{Binding ElementName=ContactButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="-120">
                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,6,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" />
                        </Border.Effect>
                        <StackPanel Width="200">
                            <ui:TextBlock Text="Kontakta oss" FontTypography="BodyStrong" Margin="0,0,0,4" />
                            <ui:TextBlock Text="Gå med i vår community på Discord."
                                          FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          TextWrapping="Wrap" Margin="0,0,0,12" />
                            <ui:Button Content="Discord" Appearance="Primary"
                                       HorizontalAlignment="Stretch" Click="DiscordButton_Click" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup x:Name="InfoPopup"
                       PlacementTarget="{Binding ElementName=InfoButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       HorizontalOffset="-300">
                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,6,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" />
                        </Border.Effect>
                        <StackPanel Width="380">
                            <ui:TextBlock Text="Information &amp; användarvillkor"
                                          FontTypography="BodyStrong" Margin="0,0,0,10" />

                            <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap" Margin="0,0,0,10"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="Detta program är skapat för " />
                                <Run Text="personligt bruk" FontWeight="SemiBold" />
                                <Run Text=" och är gratis att använda. Det bygger på öppen källkod (YoutubeExplode + FFmpeg)." />
                            </ui:TextBlock>

                            <ui:TextBlock Text="Vad som är tillåtet"
                                          FontTypography="BodyStrong" Margin="0,4,0,4" />
                            <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap" Margin="0,0,0,10"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="• Ladda ner ditt eget material." />
                                <LineBreak />
                                <Run Text="• Ladda ner videor med Creative Commons-licens." />
                                <LineBreak />
                                <Run Text="• Ladda ner innehåll där rättighetsinnehavaren uttryckligen tillåter det." />
                                <LineBreak />
                                <Run Text="• Spara videor från offentlig domän." />
                            </ui:TextBlock>

                            <ui:TextBlock Text="Vad som INTE är tillåtet"
                                          FontTypography="BodyStrong" Margin="0,4,0,4" />
                            <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap" Margin="0,0,0,10"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="• Ladda ner upphovsrättsskyddat material utan tillstånd." />
                                <LineBreak />
                                <Run Text="• Distribuera, sälja eller publicera nerladdat innehåll." />
                                <LineBreak />
                                <Run Text="• Använda materialet i kommersiellt syfte utan licens." />
                                <LineBreak />
                                <Run Text="• Kringgå betalväggar eller geo-blockeringar." />
                            </ui:TextBlock>

                            <Border Background="#33FF6B6B"
                                    BorderBrush="#FFFF6B6B"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,4,0,10">
                                <StackPanel>
                                    <ui:TextBlock Text="⚠ Risker vid felaktig användning"
                                                  FontTypography="BodyStrong"
                                                  Foreground="#FFFF8A8A"
                                                  Margin="0,0,0,6" />
                                    <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <Run Text="Att ladda ner upphovsrättsskyddat material utan tillstånd kan leda till:" />
                                        <LineBreak />
                                        <Run Text="• " /><Run Text="Civilrättsliga skadeståndskrav" FontWeight="SemiBold" /><Run Text=" från rättighetsinnehavare (kan bli mycket dyrt)." />
                                        <LineBreak />
                                        <Run Text="• " /><Run Text="Böter eller fängelse" FontWeight="SemiBold" /><Run Text=" enligt upphovsrättslagen (varierar per land)." />
                                        <LineBreak />
                                        <Run Text="• " /><Run Text="Avstängning av YouTube-konto" FontWeight="SemiBold" /><Run Text=" eller IP-blockering." />
                                        <LineBreak />
                                        <Run Text="• " /><Run Text="Krav på borttagning" FontWeight="SemiBold" /><Run Text=" (DMCA / takedown notices) om materialet sprids vidare." />
                                        <LineBreak />
                                        <Run Text="• " /><Run Text="Skadestånd vid kommersiellt bruk" FontWeight="SemiBold" /><Run Text=" — kan bli flera tusen kronor per intrång." />
                                    </ui:TextBlock>
                                </StackPanel>
                            </Border>

                            <ui:TextBlock Text="Ansvar"
                                          FontTypography="BodyStrong" Margin="0,0,0,4" />
                            <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="YouTubes användarvillkor förbjuder generellt nedladdning utan tillstånd. Genom att använda detta program bekräftar du att du själv ansvarar för hur det används och att svensk samt internationell upphovsrättslagstiftning följs. Utvecklaren tar inget juridiskt eller ekonomiskt ansvar för missbruk." />
                            </ui:TextBlock>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox Grid.Column="0"
                            PlaceholderText="Klistra in YouTube-länk här…"
                            Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                    <ui:TextBox.Style>
                        <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="PlaceholderEnabled" Value="False" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ui:TextBox.Style>
                </ui:TextBox>

                <ui:Button Grid.Column="1"
                           Margin="8,0,0,0"
                           Content="Analysera"
                           Command="{Binding AnalyzeCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Appearance" Value="Primary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPreview}" Value="True">
                                    <Setter Property="Appearance" Value="Secondary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12"
                    Visibility="{Binding HasPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="120" Height="68" CornerRadius="4" ClipToBounds="True">
                        <Image Source="{Binding PreviewThumbnail}" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <ui:TextBlock Text="{Binding PreviewTitle}" FontTypography="BodyStrong" TextTrimming="CharacterEllipsis" />
                        <ui:TextBlock Text="{Binding PreviewAuthor}" FontTypography="Caption"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                        <ui:TextBlock Text="{Binding PreviewDuration}" FontTypography="Caption"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <RadioButton Content="MP3 (ljud)" GroupName="Format"
                                 IsChecked="{Binding IsMp3}" Margin="0,0,24,0" />
                    <RadioButton Content="MP4 (video)" GroupName="Format"
                                 IsChecked="{Binding IsMp4}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding ShowQualityPicker, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:TextBlock Text="Kvalitet:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Qualities}"
                              SelectedItem="{Binding SelectedQuality}"
                              MinWidth="100" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="4" Margin="0,0,0,12"
                        Visibility="{Binding HasPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                <CheckBox Content="Trimma video" IsChecked="{Binding TrimEnabled}" />
                <Grid Margin="24,8,0,0"
                      Visibility="{Binding TrimEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" Text="Start:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ui:TextBox Grid.Column="1" Width="90" Text="{Binding TrimStart, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBlock Grid.Column="3" Text="Slut:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ui:TextBox Grid.Column="4" Width="90" Text="{Binding TrimEnd, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBlock Grid.Column="5" Text="Format: m:ss eller h:mm:ss"
                                  VerticalAlignment="Center" Margin="12,0,0,0"
                                  FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="5" Orientation="Horizontal">
                <ui:Button Content="Exportera…"
                           Padding="20,8"
                           Command="{Binding ExportCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Appearance" Value="Secondary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPreview}" Value="True">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                           ToolTip="Visa mapp"
                           Margin="8,0,0,0"
                           Padding="14,8"
                           Command="{Binding OpenLastFolderCommand}" />
                <ui:Button Content="Avbryt"
                           Margin="32,0,0,0"
                           Padding="20,8"
                           Command="{Binding CancelCommand}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>

            <ProgressBar Grid.Row="6"
                         Margin="0,16,0,8"
                         Height="6"
                         Minimum="0" Maximum="1"
                         Value="{Binding Progress}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />

            <ui:TextBlock Grid.Row="7"
                          Text="{Binding StatusText}"
                          FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Margin="0,8,0,0" />
        </Grid>
    </Grid>
</ui:FluentWindow>
