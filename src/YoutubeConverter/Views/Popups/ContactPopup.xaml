<UserControl x:Class="YoutubeConverter.Views.Popups.ContactPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            Margin="0,6,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" />
        </Border.Effect>
        <StackPanel Width="200">
            <ui:TextBlock Text="Contact us" FontTypography="BodyStrong" Margin="0,0,0,4" />
            <ui:TextBlock Text="Join our community on Discord."
                          FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          TextWrapping="Wrap" Margin="0,0,0,12" />
            <ui:Button Content="Discord" Appearance="Primary"
                       HorizontalAlignment="Stretch" Click="DiscordButton_Click" />
        </StackPanel>
    </Border>
</UserControl>
