<UserControl x:Class="YoutubeConverter.Views.Popups.HistoryPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            Margin="0,6,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.4" />
        </Border.Effect>
        <StackPanel Width="440">
            <Grid Margin="0,0,0,6">
                <ui:TextBlock Text="History" FontTypography="BodyStrong" HorizontalAlignment="Left" />
                <ui:Button Content="Clear all"
                           HorizontalAlignment="Right"
                           Padding="8,2"
                           Command="{Binding ClearHistoryCommand}"
                           Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>

            <ui:TextBlock Text="No downloads yet."
                          FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Margin="0,8"
                          HorizontalAlignment="Center">
                <ui:TextBlock.Style>
                    <Style TargetType="ui:TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasHistory}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:TextBlock.Style>
            </ui:TextBlock>

            <ListBox ItemsSource="{Binding History}"
                     MaxHeight="420"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Visibility="{Binding HasHistory, Converter={StaticResource BoolToVisibilityConverter}}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="3"
                                    Height="18"
                                    Width="24"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    ToolTip="{Binding PlatformName}">
                                <ui:TextBlock Text="{Binding PlatformIcon}"
                                              FontTypography="Caption"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentFillColorTertiaryBrush}"
                                    CornerRadius="3"
                                    Height="18"
                                    Width="36"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <ui:TextBlock Text="{Binding Format}"
                                              FontTypography="Caption"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            </Border>
                            <ui:TextBlock Grid.Column="2"
                                          Text="{Binding Title}"
                                          FontTypography="Caption"
                                          VerticalAlignment="Center"
                                          TextTrimming="CharacterEllipsis"
                                          Margin="0,0,8,0" />
                            <ui:TextBlock Grid.Column="3"
                                          Text="{Binding Timestamp, StringFormat='{}{0:MM-dd HH:mm}'}"
                                          FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0" />
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button Icon="{ui:SymbolIcon Symbol=FolderOpen24}"
                                           ToolTip="Open folder"
                                           Padding="4,2"
                                           Margin="0,0,2,0"
                                           Command="{Binding DataContext.OpenHistoryItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                           CommandParameter="{Binding}" />
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Dismiss24}"
                                           ToolTip="Remove"
                                           Padding="4,2"
                                           Command="{Binding DataContext.RemoveHistoryItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                           CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Border>
</UserControl>
