<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="YouTube Converter"
           Manufacturer="fetmamm"
           Version="$(var.Version)"
           UpgradeCode="D4F5A1C8-2B3E-4F7A-9C8D-1E2F3A4B5C6D"
           Compressed="yes"
           Scope="perMachine">

    <SummaryInformation Description="YouTube Converter installer" />
    <MajorUpgrade DowngradeErrorMessage="En nyare version av YouTube Converter är redan installerad." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon.ico" SourceFile="..\src\YoutubeConverter\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="YouTube Converter">
        <Directory Id="FfmpegDir" Name="ffmpeg">
          <Component Id="FfmpegComp">
            <File Source="$(var.PublishDir)\ffmpeg\ffmpeg.exe" KeyPath="yes" />
          </Component>
        </Directory>
        <Component Id="MainExeComp">
          <File Id="MainExe"
                Source="$(var.PublishDir)\YoutubeConverter.exe"
                KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder">
        <Shortcut Id="AppShortcut"
                  Name="YouTube Converter"
                  Description="Ladda ner YouTube-videor som MP3 eller MP4"
                  Target="[INSTALLFOLDER]YoutubeConverter.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\fetmamm\YoutubeConverter"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Directory="DesktopFolder">
        <Shortcut Id="DesktopShortcutEntry"
                  Name="YouTube Converter"
                  Target="[INSTALLFOLDER]YoutubeConverter.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\fetmamm\YoutubeConverter"
                       Name="desktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="YouTube Converter" Level="1">
      <ComponentRef Id="MainExeComp" />
      <ComponentRef Id="FfmpegComp" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>
  </Package>
</Wix>
